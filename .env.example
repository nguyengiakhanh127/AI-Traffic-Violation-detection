# Sao chép file này thành .env và điền giá trị thực vào
# Copy this file to .env and fill in the real values

# MongoDB Connection
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_NAME=traffic_violation

# Server
HOST=0.0.0.0
PORT=8000
STORAGE_DIR=storage

# Web Dashboard Auth (đổi mật khẩu trước khi deploy)
JWT_SECRET=your-secret-key-here
ADMIN_USER=admin
ADMIN_PASS=your-admin-password
REVIEWER_USER=reviewer
REVIEWER_PASS=your-reviewer-password
